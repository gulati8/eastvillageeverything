# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://eve:eve_dev_password@localhost:5432/eve_development

# Redis (for sessions)
REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=change-this-to-a-secure-random-string

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://admin.localhost:3000

# Admin seed user (bcrypt hash — generate with: npx bcrypt-cli hash "yourpassword" 10)
ADMIN_PASSWORD_HASH=
