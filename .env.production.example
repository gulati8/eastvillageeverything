# Production Environment Variables
# Copy to .env.production and fill in values

# Database
POSTGRES_USER=eve
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=eve_production
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# Session
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING

# CORS (comma-separated origins)
CORS_ORIGINS=https://eastvillageeverything.com,https://www.eastvillageeverything.com,https://admin.eastvillageeverything.com

# Domain (for CORS and cookies)
DOMAIN=eastvillageeverything.com

# Admin seed user (bcrypt hash — generate with: npx bcrypt-cli hash "yourpassword" 10)
ADMIN_PASSWORD_HASH=
