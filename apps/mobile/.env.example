# API base URL (Expo public env — must be prefixed EXPO_PUBLIC_)
# Dev (local server reachable from device): set to your machine IP
# e.g. http://192.168.1.100:3000   or   ngrok https URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# How to use this file:
#
# 1. Copy to apps/mobile/.env (gitignored).
# 2. Set EXPO_PUBLIC_API_BASE_URL to a URL your phone can reach.
#    - Same Wi-Fi as your dev machine: use your machine's LAN IP
#      (e.g. http://192.168.1.42:3000). `localhost` will NOT work
#      from a physical device — only from the iOS Simulator.
#    - Cellular / different network: use ngrok (https://ngrok.com)
#      to tunnel: `ngrok http 3000` then paste the https URL here.
# 3. Restart `npx expo start` after changing this file (Expo only
#    reads env vars at start time, not on hot reload).
#
# In built apps (preview/production), this var is set by EAS Build
# from eas.json `build.<profile>.env`. Local .env is ignored in builds.

# --- Sentry crash reporting (optional in dev; required in production) ---
# Get a DSN from https://sentry.io after creating a project for eve-mobile.
# Leave empty to disable crash reporting locally.
EXPO_PUBLIC_SENTRY_DSN=

# Override the environment label sent to Sentry. Defaults to 'production' or
# 'development' based on NODE_ENV. Useful when running a preview build that
# should report as 'preview' rather than 'production'.
EXPO_PUBLIC_SENTRY_ENVIRONMENT=

# --- Sentry source-map upload (production builds only) ---
# To upload source maps during `eas build`, set these in EAS secrets
# (NOT in eas.json — auth token is sensitive):
#   SENTRY_AUTH_TOKEN  — generate at https://sentry.io/settings/account/api/auth-tokens/
#                        scope: project:releases
#   SENTRY_ORG         — your Sentry org slug
#   SENTRY_PROJECT     — eve-mobile
# When unset, builds succeed but production crashes arrive at Sentry minified.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=eve-mobile
